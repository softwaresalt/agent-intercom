# Copy this file to .env and fill in the values before running visual tests.
# .env is gitignored — never commit credentials.

# Required: Slack workspace base URL (no trailing slash)
SLACK_WORKSPACE_URL=https://your-workspace.slack.com

# Required: Credentials for the test bot or operator account
SLACK_EMAIL=your-test-account@example.com
SLACK_PASSWORD=your-password-here

# Required: Channel name (without #) where test messages will be posted
SLACK_TEST_CHANNEL=agent-intercom-test

# Optional: Set to 'true' to force re-authentication even if auth/session.json exists
PLAYWRIGHT_FORCE_AUTH=false

# Optional: Override Playwright default action timeout in ms (default: 60000)
PLAYWRIGHT_TIMEOUT=60000

# Optional: Set to 'false' to run tests with a visible browser window (default: headless)
PLAYWRIGHT_HEADLESS=true
