# Generated by Cargo
# will have compiled files and executables
debug
target
release

# These are backup files generated by rustfmt
**/*.rs.bk
*.rlib
*.prof*

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Editor and OS noise
.idea/
.DS_Store
Thumbs.db
*.tmp
*.swp

# VS Code MCP config — contains personal channel IDs and API keys, never committed
.vscode/mcp.json

# Logs, temp files, environment
*.log
*.tmp
*.swp
*.txt
logs/
temp/
%SystemDrive%/*
.copilot/*

# Development debug scripts — contain env-specific config, never committed
run-debug-*.ps1

# SQLite runtime database files
data/*.db
data/*.db-shm
data/*.db-wal
data/*.db-journal

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Playwright Tier 3 visual test artifacts (tests/visual/)
tests/visual/node_modules/
tests/visual/auth/*.json
tests/visual/screenshots/*.png
tests/visual/reports/
tests/visual/test-results/
tests/visual/.env

# UE
*.prj
*.pui

# Dolt database files (added by bd init)
.dolt/
*.db
*.db-shm
*.db-wal
*.db-journal

# Engram runtime data (keep templates/, registry.yaml, .version)
.engram/code-graph/
.engram/db/
.engram/run/
.engram/logs/

# Autoharness runtime artifacts (keep config.yaml and workspace-profile.yaml)
.autoharness/*.lock
.autoharness/harness-manifest.yaml
.copilot-tracking/
