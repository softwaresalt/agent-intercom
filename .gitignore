# Generated by Cargo
# will have compiled files and executables
debug
target
release

# These are backup files generated by rustfmt
**/*.rs.bk
*.rlib
*.prof*

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Editor and OS noise
.idea/
.DS_Store
Thumbs.db
*.tmp
*.swp

# VS Code MCP config — contains personal channel IDs and API keys, never committed
.vscode/mcp.json

# Local environment files (secrets) — never commit. Only .env.example may be tracked.
.env
.env.local
.env.*.local
.env.*
*.env
.copilot/
.mcp.json

# Logs and temp files
*.log
*.tmp
*.swp
*.txt
logs/
temp/
tmp/
*.txt
%SystemDrive%/*

# Development debug scripts — contain env-specific config, never committed
run-debug-*.ps1

# SQLite runtime database files
data/*.db
data/*.db-shm
data/*.db-wal
data/*.db-journal

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Playwright Tier 3 visual test artifacts (tests/visual/)
tests/visual/node_modules/
tests/visual/auth/*.json
tests/visual/screenshots/*.png
tests/visual/reports/
tests/visual/test-results/
tests/visual/.env

# UE
*.prj
*.pui

# Dolt database files (added by bd init)
.dolt/
*.db
*.db-shm
*.db-wal
*.db-journal

# Engram runtime data (keep templates/, registry.yaml, .version)
.engram/
!.engram/.version
!.engram/.workspace-id
!.engram/config.toml
!.engram/registry.yaml

# Autoharness runtime artifacts (keep config.yaml and workspace-profile.yaml)
.autoharness/*.lock
**/.*.lock
.autoharness/harness-manifest.yaml
.autoharness/staging/
.autoharness/backups/
docs/experiments/
docs/closure/browser-automation/
.copilot-tracking/

# Backlogit runtime data (keep config/*.yaml, header-def, registry, and the
# durable queue/archive *.md work items). hooks_queue.jsonl is an ephemeral
# hook-event queue (poll/ack consumed) that produces spurious merge conflicts
# across branches. The SQLite cache (*.db*) and per-item logs (.backlogit/logs/)
# are already ignored above. stash.jsonl is intentionally kept tracked while it
# holds durable deferred-work entries.
.backlogit/hooks_queue.jsonl

# graphtor-docs — managed by graphtor-docs install
.graphtor/
